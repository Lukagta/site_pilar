generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SiteConfig {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}

model Doctor {
  id              Int      @id @default(autoincrement())
  name            String
  crm             String
  specialty       String
  description     String   // Resumo para a Landing Page
  fullDescription String   // Descrição completa para a página de detalhes
  imagePath       String
  isActive        Boolean  @default(true)
  order           Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
